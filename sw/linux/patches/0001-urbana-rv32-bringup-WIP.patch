+	 * reference is defined. */
 	li t6, SR_SUM
-	csrs CSR_STATUS, t6
+	/* csrs CSR_STATUS, t6 */
 
 	/*
 	 * Save the terminal address which will be used to compute the number
@@ -170,15 +173,15 @@
 	bltu	a0, t0, 4b	/* t0 - end of dst */
 
 .Lout_copy_user:
-	/* Disable access to user memory */
-	csrc CSR_STATUS, t6
+	/* URBANA: SUM stays enabled permanently; skip csrc toggle. */
+	/* csrc CSR_STATUS, t6 */
 	li	a0, 0
 	ret
 
 	/* Exception fixup code */
 10:
-	/* Disable access to user memory */
-	csrc CSR_STATUS, t6
+	/* URBANA: SUM stays enabled permanently; skip csrc toggle. */
+	/* csrc CSR_STATUS, t6 */
 	sub a0, t5, a0
 	ret
 ENDPROC(__asm_copy_to_user)
@@ -189,9 +192,9 @@
 
 ENTRY(__clear_user)
 
-	/* Enable access to user memory */
+	/* URBANA: SUM is set permanently in head.S; skip the toggle. */
 	li t6, SR_SUM
-	csrs CSR_STATUS, t6
+	/* csrs CSR_STATUS, t6 */
 
 	add a3, a0, a1
 	addi t0, a0, SZREG-1
@@ -212,8 +215,8 @@
 	bltu a0, a3, 5f
 
 3:
-	/* Disable access to user memory */
-	csrc CSR_STATUS, t6
+	/* URBANA: SUM stays enabled permanently; skip csrc toggle. */
+	/* csrc CSR_STATUS, t6 */
 	li a0, 0
 	ret
 4: /* Edge case: unalignment */
@@ -229,8 +232,8 @@
 
 	/* Exception fixup code */
 11:
-	/* Disable access to user memory */
-	csrc CSR_STATUS, t6
+	/* URBANA: SUM stays enabled permanently; skip csrc toggle. */
+	/* csrc CSR_STATUS, t6 */
 	sub a0, a3, a0
 	ret
 ENDPROC(__clear_user)
--- a/arch/riscv/include/asm/uaccess.h	2024-05-25 14:22:56.000000000 +0000
+++ b/arch/riscv/include/asm/uaccess.h	2026-04-25 12:25:24.005621950 +0000
@@ -23,10 +23,13 @@
 #include <asm/asm.h>
 #include <asm-generic/access_ok.h>
 
+/* URBANA: SUM is set permanently in head.S to dodge a silicon MMU bug
+ * where csr writes to sstatus corrupt the kernel-stack TLB entry. These
+ * macros are neutered to a pure compiler barrier; the SUM bit stays set. */
 #define __enable_user_access()							\
-	__asm__ __volatile__ ("csrs sstatus, %0" : : "r" (SR_SUM) : "memory")
+	__asm__ __volatile__ ("" : : : "memory")
 #define __disable_user_access()							\
-	__asm__ __volatile__ ("csrc sstatus, %0" : : "r" (SR_SUM) : "memory")
+	__asm__ __volatile__ ("" : : : "memory")
 
