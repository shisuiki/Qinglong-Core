Subject: [PATCH] urbana rv32 silicon bringup WIP

Combined diff for Linux 6.6.32 against pristine for the Urbana RV32IMA SoC.

Includes (per #135 bisect, all five hunks are load-bearing on this silicon):
  - arch/riscv/kernel/process.c: start_thread regs->status |= SR_SUM
    Distinct Linux-port bug — without it, first sret to user clears SUM.
  - arch/riscv/kernel/head.S: permanent sstatus.SUM=1 setup at boot
  - arch/riscv/kernel/entry.S: preserve SUM on trap entry (clear only FS_VS)
  - arch/riscv/lib/uaccess.S: neutered SUM csrs/csrc per-call toggles
  - arch/riscv/include/asm/uaccess.h: neutered SUM csrs/csrc inline toggles

Silicon bug being worked around: sstatus.SUM bit *value-change* corrupts TLB.
These four band-aids ensure SUM is set once at boot and never toggled. The
process.c fix is independent — start_thread/copy_thread sstatus init must
include SR_SUM so the first sret carries SUM=1 forward.

init/main.c bisection printks (kernel #16-23) removed, no longer needed.

---
--- a/arch/riscv/kernel/process.c	2024-05-25 14:22:56.000000000 +0000
+++ b/arch/riscv/kernel/process.c	2026-04-25 00:38:58.789075251 +0000
@@ -112,7 +112,12 @@
 void start_thread(struct pt_regs *regs, unsigned long pc,
 	unsigned long sp)
 {
-	regs->status = SR_PIE;
+	/* URBANA: keep SR_SUM in regs->status so that on every transition
+	 * back to user (csrw STATUS in ret_from_exception, then sret),
+	 * the kernel-side sstatus retains SUM=1. Otherwise the first
+	 * transition to user clears SUM permanently and copy_to_user/
+	 * copy_from_user load-page-fault on every syscall. */
+	regs->status = SR_PIE | SR_SUM;
 	if (has_fpu()) {
 		regs->status |= SR_FS_INITIAL;
 		/*
--- a/arch/riscv/kernel/head.S	2024-05-25 14:22:56.000000000 +0000
+++ b/arch/riscv/kernel/head.S	2026-04-25 11:59:00.618063225 +0000
@@ -147,6 +147,16 @@
 	li t0, SR_FS_VS
 	csrc CSR_STATUS, t0
 
+	/*
+	 * URBANA: permanently enable SSTATUS.SUM. The SoC has a silicon-only
+	 * MMU bug where a csr write to sstatus corrupts the subsequent
+	 * kernel-stack TLB entry (cause=0x0d on reload after
+	 * __clear_user / copy_to_user). Setting SUM once here lets
+	 * uaccess.S skip per-call toggles. Remove once the RTL is fixed.
+	 */
+	li t0, SR_SUM
+	csrs CSR_STATUS, t0
+
 	/* Set trap vector to spin forever to help debug */
 	la a3, .Lsecondary_park
 	csrw CSR_TVEC, a3
@@ -241,6 +251,16 @@
 	li t0, SR_FS_VS
 	csrc CSR_STATUS, t0
 
+	/*
+	 * URBANA: permanently enable SSTATUS.SUM. The SoC has a silicon-only
+	 * MMU bug where a csr write to sstatus corrupts the subsequent
+	 * kernel-stack TLB entry (cause=0x0d on reload after
+	 * __clear_user / copy_to_user). Setting SUM once here lets
+	 * uaccess.S skip per-call toggles. Remove once the RTL is fixed.
+	 */
+	li t0, SR_SUM
+	csrs CSR_STATUS, t0
+
 #ifdef CONFIG_RISCV_BOOT_SPINWAIT
 	li t0, CONFIG_NR_CPUS
 	blt a0, t0, .Lgood_cores
--- a/arch/riscv/kernel/entry.S	2024-05-25 14:22:56.000000000 +0000
+++ b/arch/riscv/kernel/entry.S	2026-04-25 12:28:49.972263829 +0000
@@ -49,13 +49,11 @@
 	save_from_x6_to_x31
 
 	/*
-	 * Disable user-mode memory access as it should only be set in the
-	 * actual user copy routines.
-	 *
-	 * Disable the FPU/Vector to detect illegal usage of floating point
-	 * or vector in kernel space.
+	 * URBANA: preserve SUM on trap entry. The SoC's MMU corrupts the
+	 * kernel-stack TLB entry on csr writes that clear/set SUM, so we
+	 * keep SUM set globally (see head.S) and only clear FPU/Vector here.
 	 */
-	li t0, SR_SUM | SR_FS_VS
+	li t0, SR_FS_VS
 
 	REG_L s0, TASK_TI_USER_SP(tp)
 	csrrc s1, CSR_STATUS, t0
--- a/arch/riscv/lib/uaccess.S	2024-05-25 14:22:56.000000000 +0000
+++ b/arch/riscv/lib/uaccess.S	2026-04-25 12:25:24.003621905 +0000
@@ -13,9 +13,12 @@
 ENTRY(__asm_copy_to_user)
 ENTRY(__asm_copy_from_user)
 
-	/* Enable access to user memory */
